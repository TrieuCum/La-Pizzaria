@{
    ViewData["Title"] = "Menu";
    var products = ViewBag.Products as List<LaPizzaria.Models.Product> ?? new();
    var combos = ViewBag.Combos as List<LaPizzaria.Models.Combo> ?? new();
    var categories = ViewBag.Categories as List<string> ?? new();
    var selectedCategory = ViewBag.SelectedCategory as string ?? "Tất cả";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .menu-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s;
        cursor: pointer;
        height: 100%;
    }
    .menu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }
    .menu-img {
        height: 200px;
        object-fit: cover;
    }
    .category-filter {
        border: 2px solid #eee;
        border-radius: 10px;
        padding: 10px 20px;
        margin: 5px;
        cursor: pointer;
        transition: all 0.3s;
    }
    .category-filter:hover,
    .category-filter.active {
        border-color: #da291c;
        background: #fff5f5;
        color: #da291c;
        font-weight: 600;
    }
</style>

<div class="container mb-5">
    <h2 class="text-center mb-4"><i class="bi bi-menu-button-wide me-2"></i>Menu</h2>

    <!-- Category Filter -->
    <div class="d-flex flex-wrap justify-content-center mb-4">
        <div class="category-filter @(selectedCategory == "Tất cả" ? "active" : "")" onclick="filterCategory('Tất cả')">
            Tất cả
        </div>
        @foreach (var cat in categories)
        {
            <div class="category-filter @(selectedCategory == cat ? "active" : "")" onclick="filterCategory('@cat')">
                @cat
            </div>
        }
        <div class="category-filter @(selectedCategory == "Combo" ? "active" : "")" onclick="filterCategory('Combo')">
            Combo
        </div>
    </div>

    <!-- Products Grid -->
    <div class="row g-4" id="menuGrid">
        @foreach (var product in products)
        {
            <div class="col-md-4 col-lg-3" data-category="@product.Category">
                <div class="card menu-card">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" class="card-img-top menu-img" alt="@product.Name">
                    }
                    else
                    {
                        <div class="menu-img bg-light d-flex align-items-center justify-content-center">
                            <span style="font-size: 3rem;">🍕</span>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="text-muted small mb-2">@product.Category</p>
                        @if (!string.IsNullOrEmpty(product.Description))
                        {
                            <p class="card-text small text-muted flex-grow-1">@product.Description</p>
                        }
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <strong class="text-danger fs-5">@product.Price.ToString("N0")đ</strong>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <button type="button" class="btn btn-primary btn-sm" onclick="addToCart(@product.Id, '@product.Name', @product.Price)">
                                    <i class="bi bi-cart-plus me-1"></i>Thêm
                                </button>
                            }
                            else
                            {
                                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-cart-plus me-1"></i>Thêm
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @foreach (var combo in combos)
        {
            var fallbackImg = combo.Items.FirstOrDefault(i => i.Product != null && !string.IsNullOrEmpty(i.Product.ImageUrl))?.Product?.ImageUrl;
            var img = !string.IsNullOrEmpty(combo.ImageUrl) ? combo.ImageUrl : fallbackImg;
            var raw = combo.Items.Where(i => i.Product != null).Select(i => i.Product!.Price * i.MinQuantity).DefaultIfEmpty(0m).Sum();
            var afterAmount = raw - (combo.DiscountAmount > 0 ? combo.DiscountAmount : 0);
            var afterPercent = combo.DiscountPercent.HasValue ? afterAmount * (1 - (combo.DiscountPercent.Value / 100m)) : afterAmount;
            var comboPrice = afterPercent < 0 ? 0 : afterPercent;

            <div class="col-md-4 col-lg-3" data-category="Combo">
                <div class="card menu-card position-relative">
                    <span class="badge bg-danger position-absolute top-0 start-0 m-2">Combo</span>
                    @if (!string.IsNullOrEmpty(img))
                    {
                        <img src="@img" class="card-img-top menu-img" alt="@combo.Name">
                    }
                    else
                    {
                        <div class="menu-img bg-light d-flex align-items-center justify-content-center">
                            <span style="font-size: 3rem;">🍕</span>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@combo.Name</h5>
                        <p class="text-muted small mb-2">Combo</p>
                        <p class="card-text small text-muted flex-grow-1">
                            @string.Join(", ", combo.Items.Where(i => i.Product != null).Select(i => $"{i.Product!.Name} x{i.MinQuantity}"))
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <strong class="text-danger fs-5">@comboPrice.ToString("N0")đ</strong>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <button type="button" class="btn btn-primary btn-sm" onclick="alert('Combo sẽ được thêm vào giỏ hàng sớm!')">
                                    <i class="bi bi-cart-plus me-1"></i>Thêm
                                </button>
                            }
                            else
                            {
                                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-cart-plus me-1"></i>Thêm
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
function filterCategory(category) {
    window.location.href = `/Menu?category=${encodeURIComponent(category)}`;
}

async function addToCart(productId, productName, price) {
    try {
        const response = await fetch('/Cart/Add', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify({ productId, quantity: 1 })
        });
        
        if (response.ok) {
            if (window.showToast) {
                window.showToast(`Đã thêm ${productName} vào giỏ hàng!`, 'success');
            } else {
                alert(`Đã thêm ${productName} vào giỏ hàng!`);
            }
            
            // Update cart count
            if (typeof loadCartCount === 'function') {
                loadCartCount();
            }
        } else {
            if (window.showToast) {
                window.showToast('Có lỗi xảy ra khi thêm vào giỏ hàng', 'error');
            }
        }
    } catch (e) {
        console.error('Failed to add to cart', e);
        if (window.showToast) {
            window.showToast('Có lỗi xảy ra khi thêm vào giỏ hàng', 'error');
        }
    }
}
</script>
