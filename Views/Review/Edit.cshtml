@model LaPizzaria.Models.Review
@{
    ViewData["Title"] = "Sửa đánh giá";
    var order = ViewBag.Order as LaPizzaria.Models.Order;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .rating-option {
        cursor: pointer;
        padding: 10px 20px;
        border: 2px solid #ddd;
        border-radius: 10px;
        margin: 5px;
        transition: all 0.3s;
        text-align: center;
    }
    .rating-option:hover {
        border-color: #ffc107;
        background: #fff9e6;
    }
    .rating-option.selected {
        border-color: #ffc107;
        background: #fff9e6;
    }
    .star-preview {
        font-size: 2rem;
        color: #ffc107;
    }
</style>

<div class="container mb-5">
    <h2 class="mb-4"><i class="bi bi-pencil me-2"></i>Sửa đánh giá</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="card">
        <div class="card-body p-4">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OrderId" />

            <div class="mb-4">
                <label class="form-label fw-bold">Đánh giá của bạn <span class="text-danger">*</span></label>
                <div class="d-flex flex-wrap" id="ratingOptions">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var labels = new[] { "Tệ", "Không hài lòng", "Bình thường", "Hài lòng", "Rất hài lòng" };
                        <div class="rating-option @(i == Model.Rating ? "selected" : "")" data-rating="@i">
                            <div class="star-preview">@string.Join("", Enumerable.Repeat("⭐", i))</div>
                            <div>@labels[i-1]</div>
                        </div>
                    }
                </div>
                <input type="hidden" asp-for="Rating" id="ratingInput" required />
            </div>

            <div class="mb-4">
                <label asp-for="Comment" class="form-label fw-bold">Đánh giá chi tiết</label>
                <textarea asp-for="Comment" class="form-control" rows="5"></textarea>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Hình ảnh hiện tại</label>
                    <img src="@Model.ImageUrl" alt="Review image" class="img-thumbnail" style="max-width: 300px;">
                </div>
            }

            <div class="mb-4">
                <label class="form-label fw-bold">Thay đổi hình ảnh</label>
                <input type="file" name="reviewImage" class="form-control" accept="image/*" />
                <small class="text-muted">Tối đa 5MB (JPG, PNG, GIF)</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </div>
    </form>
</div>

<partial name="_ValidationScriptsPartial" />

<script>
document.querySelectorAll('.rating-option').forEach(option => {
    option.addEventListener('click', function() {
        document.querySelectorAll('.rating-option').forEach(opt => opt.classList.remove('selected'));
        this.classList.add('selected');
        document.getElementById('ratingInput').value = this.dataset.rating;
    });
});
</script>
