@model LaPizzaria.ViewModels.CustomerDetailViewModel
@{ ViewData["Title"] = "Chi tiết Khách hàng"; }

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary-red: #da291c;
        --light-cream: #f8f5ed;
        --wood-brown: #5a2e0a;
    }
    .brand-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        background: white;
        overflow: hidden;
        margin-bottom: 2rem;
    }
    .btn-brand-primary {
        background-color: var(--primary-red);
        border-color: var(--primary-red);
        color: white;
        font-weight: bold;
    }
    .btn-brand-primary:hover {
        background-color: var(--wood-brown);
        border-color: var(--wood-brown);
        color: white;
    }
    .avatar-large {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border: 4px solid var(--primary-red);
    }
    .stat-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
    }
    .stat-card.success {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }
    .stat-card.warning {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
    .stat-card.info {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }
</style>

<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Chi tiết Khách hàng</h2>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Quay lại
        </a>
    </div>

    <!-- Profile Card -->
    <div class="brand-card p-4">
        <div class="row">
            <div class="col-md-3 text-center">
                @if (!string.IsNullOrEmpty(Model.User.AvatarUrl))
                {
                    <img src="@Model.User.AvatarUrl" alt="Avatar" class="avatar-large rounded-circle mb-3">
                }
                else
                {
                    <div class="avatar-large rounded-circle mb-3 d-flex align-items-center justify-content-center bg-secondary text-white mx-auto" style="font-size: 3rem; font-weight: bold;">
                        @(Model.User.FirstName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                    </div>
                }
                <h4 class="fw-bold">@Model.User.FirstName @Model.User.LastName</h4>
                <p class="text-muted mb-0">@Model.User.Email</p>
            </div>
            <div class="col-md-9">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small">Số điện thoại</label>
                        <p class="mb-0">@(Model.User.PhoneNumber ?? "Chưa có")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Ngày sinh</label>
                        <p class="mb-0">@(Model.User.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Giới tính</label>
                        <p class="mb-0">@(Model.User.Gender ?? "Chưa cập nhật")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Địa chỉ mặc định</label>
                        <p class="mb-0">@(Model.User.DefaultAddress ?? "Chưa cập nhật")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Tư cách hội viên</label>
                        <p class="mb-0">
                            @if (Model.User.IsMember)
                            {
                                <span class="badge bg-success">Hội viên</span>
                                @if (Model.User.MemberSince.HasValue)
                                {
                                    <small class="text-muted ms-2">Từ @Model.User.MemberSince.Value.ToString("dd/MM/yyyy")</small>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa đăng ký</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Điểm tích lũy</label>
                        <p class="mb-0">
                            <span class="badge bg-danger fs-6">@Model.User.LoyaltyPoints.ToString("N0") điểm</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <i class="bi bi-cart-check" style="font-size: 2rem;"></i>
                <h3 class="mt-2 mb-0">@Model.TotalOrders</h3>
                <small>Đơn hàng</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card success">
                <i class="bi bi-currency-dollar" style="font-size: 2rem;"></i>
                <h3 class="mt-2 mb-0">@Model.TotalSpent.ToString("N0")đ</h3>
                <small>Tổng chi tiêu</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card warning">
                <i class="bi bi-star" style="font-size: 2rem;"></i>
                <h3 class="mt-2 mb-0">@Model.TotalReviews</h3>
                <small>Đánh giá</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card info">
                <i class="bi bi-graph-up" style="font-size: 2rem;"></i>
                <h3 class="mt-2 mb-0">@Model.AverageOrderValue.ToString("N0")đ</h3>
                <small>Trung bình/đơn</small>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="brand-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Thao tác</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <form method="post" action="@Url.Action("ToggleMembership", new { id = Model.User.Id })">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-@(Model.User.IsMember ? "warning" : "success") w-100">
                        <i class="bi bi-@(Model.User.IsMember ? "x-circle" : "star-fill") me-2"></i>
                        @(Model.User.IsMember ? "Hủy tư cách hội viên" : "Kích hoạt hội viên")
                    </button>
                </form>
            </div>
            <div class="col-md-6">
                <button type="button" class="btn btn-brand-primary w-100" data-bs-toggle="modal" data-bs-target="#adjustPointsModal">
                    <i class="bi bi-pencil me-2"></i>Điều chỉnh điểm
                </button>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="brand-card p-4">
        <h5 class="fw-bold mb-3">Đơn hàng gần đây</h5>
        @if (Model.RecentOrders.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td>#@order.OrderCode</td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-success">@order.TotalPrice.ToString("N0")đ</td>
                                <td>
                                    <span class="badge bg-@(order.OrderStatus == "Hoàn thành" ? "success" : order.OrderStatus == "Đã hủy" ? "danger" : "warning")">
                                        @order.OrderStatus
                                    </span>
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", "Order", new { id = order.Id })" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center py-4">Chưa có đơn hàng nào</p>
        }
    </div>

    <!-- Favorite Products -->
    @if (Model.FavoriteProducts.Any())
    {
        <div class="brand-card p-4">
            <h5 class="fw-bold mb-3">Món yêu thích</h5>
            <div class="row g-3">
                @foreach (var product in Model.FavoriteProducts)
                {
                    <div class="col-md-3">
                        <div class="card">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" class="card-img-top" style="height: 150px; object-fit: cover;">
                            }
                            <div class="card-body">
                                <h6 class="card-title">@product.Name</h6>
                                <p class="text-danger fw-bold mb-0">@product.Price.ToString("N0")đ</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Adjust Points Modal -->
<div class="modal fade" id="adjustPointsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Điều chỉnh điểm tích lũy</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="@Url.Action("AdjustPoints", new { id = Model.User.Id })">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Số điểm hiện tại</label>
                        <input type="text" class="form-control" value="@Model.User.LoyaltyPoints.ToString("N0") điểm" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Điều chỉnh điểm <span class="text-danger">*</span></label>
                        <input type="number" name="points" class="form-control" required placeholder="Nhập số điểm (âm để trừ, dương để cộng)">
                        <small class="text-muted">Ví dụ: +100 để cộng, -50 để trừ</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lý do <span class="text-danger">*</span></label>
                        <textarea name="reason" class="form-control" rows="3" required placeholder="Nhập lý do điều chỉnh điểm"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-brand-primary">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>
