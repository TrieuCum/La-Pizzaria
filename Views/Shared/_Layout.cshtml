<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LaPizzaria</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
        .navbar-brand { font-family: 'Playfair Display', serif; font-weight: 900; letter-spacing: .5px; }
    </style>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LaPizzaria.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light brand-navbar modern-navbar">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center modern-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-logo modern-logo me-2">🍕</span>
                    <span class="brand-text">LaPizzaria</span>
                </a>
                <button class="navbar-toggler modern-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 modern-nav">
                        <li class="nav-item">
                            <a class="nav-link modern-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <span class="nav-text">Home</span>
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link modern-nav-link" asp-area="" asp-controller="Product" asp-action="Index">
                                    <span class="nav-text">Products</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link modern-nav-link" asp-area="" asp-controller="Menu" asp-action="Index">
                                    <span class="nav-text">Menu</span>
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link modern-nav-link" asp-area="" asp-controller="Table" asp-action="Index">
                                <span class="nav-text">Tables</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link modern-nav-link" asp-area="" asp-controller="Ingredient" asp-action="Index">
                                <span class="nav-text">Ingredients</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link modern-nav-link" asp-area="" asp-controller="Order" asp-action="Index">
                                <span class="nav-text">Orders</span>
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link modern-nav-link" asp-area="" asp-controller="Voucher" asp-action="Index">
                                    <span class="nav-text">Vouchers</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link modern-nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="nav-text">Quản lý</span>
                                </a>
                                <ul class="dropdown-menu modern-dropdown">
                                    <li><a class="dropdown-item modern-dropdown-item" asp-area="" asp-controller="UserManagement" asp-action="Index">👤 Tài khoản</a></li>
                                    <li><a class="dropdown-item modern-dropdown-item" asp-area="" asp-controller="Customer" asp-action="Index">👥 Khách hàng</a></li>
                                    <li><a class="dropdown-item modern-dropdown-item" asp-area="" asp-controller="Employee" asp-action="Index">👥 Nhân viên</a></li>
                                </ul>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link modern-nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="nav-text">Statistics</span>
                            </a>
                            <ul class="dropdown-menu modern-dropdown">
                                <li><a class="dropdown-item modern-dropdown-item" asp-area="" asp-controller="Statistics" asp-action="Daily">📅 Daily</a></li>
                                <li><a class="dropdown-item modern-dropdown-item" asp-area="" asp-controller="Statistics" asp-action="Weekly">📈 Weekly</a></li>
                            </ul>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="position-relative">
                                <button type="button" class="btn btn-outline-primary position-relative" id="cartIcon" onmouseenter="loadCartPopup()">
                                    <i class="bi bi-cart3"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cartBadge" style="display: none;">0</span>
                                </button>
                                <!-- Cart Popup -->
                                <div class="position-absolute end-0 mt-2" id="cartPopup" style="display: none; width: 350px; z-index: 1050; background: white; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.15);" onmouseleave="hideCartPopup()">
                                    <div class="p-3 border-bottom">
                                        <h6 class="mb-0"><i class="bi bi-cart3 me-2"></i>Giỏ hàng</h6>
                                    </div>
                                    <div id="cartItems" style="max-height: 400px; overflow-y: auto;" class="p-3">
                                        <p class="text-muted text-center py-3">Đang tải...</p>
                                    </div>
                                    <div class="p-3 border-top">
                                        <div class="d-flex justify-content-between mb-3">
                                            <strong>Tổng:</strong>
                                            <strong class="text-danger" id="cartTotal">0đ</strong>
                                        </div>
                                        <a href="@Url.Action("Index", "Checkout")" class="btn btn-primary w-100">
                                            <i class="bi bi-check-circle me-2"></i>Thanh toán
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Global toast container -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
        <div id="toastContainer" class="toast-container"></div>
    </div>

    <footer class="brand-footer">
        <div class="container py-4">
            <div class="row g-3 align-items-center">
                <div class="col-md-6 small">
                    <div class="mb-1 fw-bold">LaPizzaria</div>
                    <div class="text-opacity-75">Hương vị đích thực từ lò nướng Ý</div>
                </div>
                <div class="col-md-6 text-md-end">
                    <a class="footer-link me-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a class="footer-link me-3" asp-area="" asp-controller="Order" asp-action="Qr">QR</a>
                    <a class="footer-link" asp-area="" asp-controller="Product" asp-action="Index">Menu</a>
                </div>
            </div>
            <div class="pt-3 small text-center text-md-start text-light-50">&copy; 2025 LaPizzaria. All rights reserved.</div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function(){
            // Render TempData as toasts if present
            const success = '@(TempData["success"] ?? string.Empty)';
            const error = '@(TempData["error"] ?? string.Empty)';
            if (success) window.showToast && window.showToast(success, 'success');
            if (error) window.showToast && window.showToast(error, 'error');
            
            // Load cart count on page load
            @if (User.Identity?.IsAuthenticated == true)
            {
                <text>
                loadCartCount();
                </text>
            }
        })();

        let cartPopupTimeout;
        
        async function loadCartCount() {
            try {
                const response = await fetch('/Cart/GetCart');
                const data = await response.json();
                const badge = document.getElementById('cartBadge');
                if (data.itemCount > 0) {
                    badge.textContent = data.itemCount;
                    badge.style.display = 'block';
                } else {
                    badge.style.display = 'none';
                }
            } catch (e) {
                console.error('Failed to load cart count', e);
            }
        }

        async function loadCartPopup() {
            clearTimeout(cartPopupTimeout);
            const popup = document.getElementById('cartPopup');
            popup.style.display = 'block';
            
            try {
                const response = await fetch('/Cart/GetCart');
                const data = await response.json();
                
                const itemsContainer = document.getElementById('cartItems');
                const totalElement = document.getElementById('cartTotal');
                
                if (data.items.length === 0) {
                    itemsContainer.innerHTML = '<p class="text-muted text-center py-3">Giỏ hàng trống</p>';
                    totalElement.textContent = '0đ';
                    return;
                }
                
                let html = '';
                data.items.forEach(item => {
                    html += `
                        <div class="d-flex align-items-center mb-3 pb-3 border-bottom" data-item-id="${item.id}">
                            ${item.imageUrl ? `<img src="${item.imageUrl}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px; margin-right: 10px;">` : ''}
                            <div class="flex-grow-1">
                                <div class="fw-bold small">${item.name}</div>
                                <div class="text-muted small">${item.price.toLocaleString()}đ x ${item.quantity}</div>
                            </div>
                            <div class="text-end me-2">
                                <strong class="text-danger">${item.subtotal.toLocaleString()}đ</strong>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeFromCart(${item.id})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    `;
                });
                itemsContainer.innerHTML = html;
                totalElement.textContent = data.total.toLocaleString() + 'đ';
            } catch (e) {
                console.error('Failed to load cart', e);
                document.getElementById('cartItems').innerHTML = '<p class="text-danger text-center py-3">Lỗi tải giỏ hàng</p>';
            }
        }

        function hideCartPopup() {
            cartPopupTimeout = setTimeout(() => {
                document.getElementById('cartPopup').style.display = 'none';
            }, 300);
        }

        async function removeFromCart(itemId) {
            try {
                const response = await fetch(`/Cart/Remove?itemId=${itemId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                });
                if (response.ok) {
                    loadCartPopup();
                    loadCartCount();
                }
            } catch (e) {
                console.error('Failed to remove item', e);
            }
        }

        // Keep popup open when hovering over it
        document.getElementById('cartPopup')?.addEventListener('mouseenter', () => {
            clearTimeout(cartPopupTimeout);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
