@model IEnumerable<LaPizzaria.Models.Employee>
@{
    ViewData["Title"] = "Quản lý Nhân viên";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/employee-dashboard.css" rel="stylesheet" />
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="admin-info">
                <div class="admin-avatar"></div>
                <div class="admin-details">
                    <h3>Pizza Admin</h3>
                    <p>Quản trị viên</p>
                </div>
            </div>
            
            <nav class="sidebar-menu">
                <a href="#" class="menu-item">
                    <i class="fas fa-chart-bar"></i>
                    <span>Thống kê</span>
                </a>
                <a href="#" class="menu-item active">
                    <i class="fas fa-users"></i>
                    <span>Quản lý nhân viên</span>
                </a>
                <a href="#" class="menu-item">
                    <i class="fas fa-table"></i>
                    <span>Đặt bàn</span>
                </a>
                <a href="#" class="menu-item">
                    <i class="fas fa-leaf"></i>
                    <span>Nguyên liệu</span>
                </a>
                <a href="#" class="menu-item">
                    <i class="fas fa-ticket-alt"></i>
                    <span>Voucher</span>
                </a>
                <a href="#" class="menu-item">
                    <i class="fas fa-user-friends"></i>
                    <span>Quản lý khách hàng</span>
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="#" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="top-header">
                <div class="header-left">
                    <div class="logo">
                        <i class="fas fa-pizza-slice"></i>
                        <span>LaPizzaria</span>
                    </div>
                </div>
                
                <nav class="header-nav">
                    <a href="#">Trang chủ</a>
                    <a href="#">Món ăn</a>
                    <a href="#">Khuyến mãi</a>
                    <a href="#">Đơn hàng của tôi</a>
                    <a href="#">Tích điểm</a>
                </nav>
                
                <div class="header-right">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Tìm kiếm...">
                    </div>
                    <button class="profile-btn">
                        <i class="fas fa-user"></i>
                        <span>Hồ sơ</span>
                    </button>
                    <div class="cart-icon">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-badge">3</span>
                    </div>
                </div>
            </header>


            <!-- Page Content -->
            <div class="page-content">
                <!-- Page Header -->
                <div class="page-header">
                    <div class="page-title">
                        <h1>Quản lý Nhân viên</h1>
                        <p>Xem và quản lý danh sách nhân viên trong hệ thống</p>
                    </div>
                    <a href="@Url.Action("Create")" class="add-btn">
                        <i class="fas fa-plus"></i>
                        <span>Thêm nhân viên mới</span>
                    </a>
                </div>

                <!-- Filter Bar -->
                <div class="filter-bar">
                    <div class="search-input">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Tìm kiếm nhân viên..." id="searchInput">
                    </div>
                    <select class="filter-select" id="positionFilter">
                        <option value="">Lọc theo chức vụ</option>
                        <option value="Quản lý">Quản lý</option>
                        <option value="Thu ngân">Thu ngân</option>
                        <option value="Đầu bếp">Đầu bếp</option>
                        <option value="Phục vụ">Phục vụ</option>
                        <option value="Shipper">Shipper</option>
                    </select>
                    <select class="filter-select" id="statusFilter">
                        <option value="">Lọc theo trạng thái</option>
                        <option value="Đang làm">Đang làm việc</option>
                        <option value="Nghỉ phép">Nghỉ phép</option>
                        <option value="Nghỉ việc">Nghỉ việc</option>
                    </select>
                </div>

                <!-- Employee Table -->
                <div class="table-container">
                    <table class="employee-table">
                        <thead>
                            <tr>
                                <th>Tên nhân viên</th>
                                <th>Chức vụ</th>
                                <th>Số điện thoại</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="employee-info">
                                            <div class="employee-avatar"></div>
                                            <div class="employee-details">
                                                <div class="employee-name">@employee.FullName</div>
                                                <div class="employee-id">@employee.EmployeeCode</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="position-badge">@employee.Position</span>
                                    </td>
                                    <td>@employee.PhoneNumber</td>
                                    <td>
                                        <div class="status-indicator @(employee.Status == "Đang làm" ? "active" : "inactive")">
                                            <span class="status-dot"></span>
                                            <span>@employee.Status</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <a href="@Url.Action("Edit", new { id = employee.Id })" class="action-btn edit-btn">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button class="action-btn delete-btn" onclick="deleteEmployee(@employee.Id)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="pagination">
                    <div class="pagination-info">
                        <span>Hiển thị 1-@Model.Count() trên @Model.Count() nhân viên</span>
                    </div>
                    <div class="pagination-controls">
                        <button class="page-btn active">1</button>
                        <button class="page-btn">2</button>
                        <button class="page-btn">3</button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        function deleteEmployee(id) {
            if (confirm('Bạn có chắc chắn muốn xóa nhân viên này?')) {
                fetch(`/Employee/Delete/${id}`, {
                    method: 'DELETE'
                }).then(response => {
                    if (response.ok) {
                        location.reload();
                    }
                });
            }
        }

        // Filter functionality
        document.getElementById('positionFilter').addEventListener('change', filterEmployees);
        document.getElementById('statusFilter').addEventListener('change', filterEmployees);
        document.getElementById('searchInput').addEventListener('input', filterEmployees);

        function filterEmployees() {
            const positionFilter = document.getElementById('positionFilter').value;
            const statusFilter = document.getElementById('statusFilter').value;
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            const rows = document.querySelectorAll('.employee-table tbody tr');
            
            rows.forEach(row => {
                const name = row.querySelector('.employee-name').textContent.toLowerCase();
                const position = row.querySelector('.position-badge').textContent.trim();
                const status = row.querySelector('.status-indicator span:last-child').textContent.trim();
                
                const matchesSearch = name.includes(searchTerm);
                const matchesPosition = !positionFilter || position === positionFilter;
                const matchesStatus = !statusFilter || status === statusFilter;
                
                row.style.display = (matchesSearch && matchesPosition && matchesStatus) ? '' : 'none';
            });
        }
    </script>
</body>
</html>